APP_NAME_IN_HOME_PAGE="{{ app_name | default('Catracas Secretaria') }}"
APP_ENVIRONMENT={{ app_env | default('prod') }}
APP_DEBUG_MODE={{ app_debug | default('false') }}
GOOGLE_ANALYTICS_ID={{ google_analytics_id | default('') }}
GOOGLE_TAG_MANAGER_ID={{ google_tag_manager_id | default('') }}
DEFAULT_ADMIN_USERNAME={{ default_admin_username | default('admin') }}
DEFAULT_ADMIN_PASSWORD={{ default_admin_password }}

FIREBASE_AUTH_EMAIL_USER="{{ firebase_auth_email }}"
FIREBASE_AUTH_PASSWORD="{{ firebase_auth_password }}"
FIREBASE_ID_TOKEN={{ firebase_id_token | default('') }}

FIREBASE_REQUEST_TIMEOUT={{ firebase_timeout | default('10.0') }}
FIREBASE_FIRESTORE_BASE_URI="{{ firebase_firestore_uri | default('https://firestore.googleapis.com') }}"
FIREBASE_CONFIG_API_KEY="{{ firebase_api_key }}"
FIREBASE_CONFIG_AUTH_DOMAIN="{{ firebase_auth_domain }}"
FIREBASE_CONFIG_PROJECT_ID="{{ firebase_project_id }}"
FIREBASE_CONFIG_STORAGE_BUCKET="{{ firebase_storage_bucket }}"
FIREBASE_CONFIG_MESSAGING_SENDER_ID="{{ firebase_messaging_id }}"
FIREBASE_CONFIG_APP_ID="{{ firebase_app_id }}"
FIREBASE_CONFIG_MEASUREMENT_ID="{{ firebase_measurement_id | default('') }}"

PDO_DSN='mysql:host=eteczlcatracas-mysql;dbname=eteczlcatracas_db'
DB_USER='eteczlcatracas_user'
DB_PASS='{{ db_password }}'
